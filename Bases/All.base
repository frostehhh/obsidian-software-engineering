filters:
  and:
    - '!file.name.contains("Table of Contents")'
    - '!file.name.startsWith("_note_")'
views:
  - type: table
    name: All
    filters:
      and:
        - file.tags.contains("data-structures")
    order:
      - file.name
      - tags
      - aliases
      - file.folder
    sort:
      - property: tags
        direction: ASC
      - property: file.name
        direction: ASC
      - property: file.basename
        direction: DESC
