filters:
  and:
    - '!file.name.contains("Table of Contents")'
    - '!file.name.startsWith("_note_")'
    - file.hasTag("artificial-intelligence")
views:
  - type: table
    name: All
    order:
      - file.name
      - tags
      - file.folder
    sort:
      - property: file.name
        direction: ASC
      - property: file.basename
        direction: DESC
    columnSize:
      file.name: 425
