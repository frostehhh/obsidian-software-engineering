filters:
  and:
    - '!file.name.contains("Table of Contents")'
    - '!file.name.startsWith("_note_")'
    - file.hasTag("guide")
views:
  - type: table
    name: All
    order:
      - file.name
      - tags
      - aliases
      - file.folder
      - Draft
    sort:
      - property: Draft
        direction: ASC
      - property: file.name
        direction: ASC
      - property: file.basename
        direction: DESC
    columnSize:
      note.tags: 328
      file.folder: 276
