filters:
  and:
    - '!file.name.contains("Table of Contents")'
    - '!file.name.startsWith("_note_")'
    - or:
        - file.folder.startsWith("Mindmaps")
        - file.tags.contains("mindmap")
views:
  - type: table
    name: All
    order:
      - file.name
      - tags
      - aliases
      - file.folder
    sort:
      - property: file.name
        direction: ASC
      - property: file.basename
        direction: DESC
