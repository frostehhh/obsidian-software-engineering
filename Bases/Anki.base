filters:
  and:
    - '!file.name.contains("Table of Contents")'
    - '!file.name.startsWith("_note_")'
    - and:
        - file.hasTag("flashcards")
views:
  - type: table
    name: All
    order:
      - file.name
      - tags
      - aliases
      - file.folder
    sort:
      - property: file.name
        direction: ASC
      - property: file.basename
        direction: DESC
  - type: table
    name: Draft
    filters:
      and:
        - Draft == true
