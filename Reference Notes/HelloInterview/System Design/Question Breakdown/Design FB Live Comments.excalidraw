      "fontSize": 30,
      "fontFamily": 3,
      "text": "Facebook Live Comments is a feature that enables viewers to post comments on a live video feed. Viewers can see\na continuous stream of comments in near-real-time.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Facebook Live Comments is a feature that enables viewers to post comments on a live video feed. Viewers can see\na continuous stream of comments in near-real-time.",
      "lineHeight": 1.25,
      "baseline": 66
