{
  "ribbonIcon": true,
  "ribbonCommandUsesCode": true,
  "showFileContextMenuItem": true,
  "executeTemplate": "\"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" -g \"{{vaultpath}}\" \"{{vaultpath}}/{{filepath}}\"",
  "urlProtocol": "vscode",
  "openFile": true,
  "workspacePath": "{{vaultpath}}",
  "useUrlInsiders": false
}